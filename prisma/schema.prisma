generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Commerce {
  id         String    @id @default(uuid())
  name       String
  ownerPhone String    @unique
  rfc        String
  createdAt  DateTime  @default(now())
  invoices   Invoice[]
}

model Invoice {
  id             String        @id @default(uuid())
  amount         Float
  customerRfc    String
  customerEmail  String
  status         InvoiceStatus @default(PENDING_CONFIRMATION)
  facturapiId    String?
  createdAt      DateTime      @default(now())
  commerceId     String
  razon_social   String?
  regimen_fiscal String?
  uso_cfdi       String?
  codigo_postal  String?
  commerce       Commerce      @relation(fields: [commerceId], references: [id])
}

enum InvoiceStatus {
  PENDING_CONFIRMATION
  REJECTED
  STAMPED
}
